# API Defaults
DEFAULT_PROVIDER=Nvidia

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
