# API Defaults
DEFAULT_PROVIDER=OpenRouter
MACRO_LOG_ROOT=C:\Logs\MacroDashboard

# OpenRouter Configuration (Unified access for all models)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Note: Provider-specific keys (GOOGLE_API_KEY, ANTHROPIC_API_KEY, etc.) are no longer required.

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Macro Data Sources
FRED_API_KEY=your_fred_api_key_here

# Orchestration Settings
GEMINI_THROTTLE_SEC=8.0
