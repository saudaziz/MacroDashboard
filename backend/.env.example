# API Defaults
DEFAULT_PROVIDER=Bytedance Seed
MACRO_LOG_ROOT=C:\Logs\MacroDashboard

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-haiku-20240307

# Qwen AI Endpoints (via NVIDIA)
QWEN_API_KEY=your_nvidia_api_key_here
QWEN_MODEL=qwen/qwen3.5-397b-a17b
QWEN_MAX_TOKENS=4096

# Bytedance (via NVIDIA Integration)
BYTEDANCE_API_KEY=your_bytedance_api_key_here
BYTEDANCE_MODEL=bytedance/seed-oss-36b-instruct

# DeepSeek (via NVIDIA Integration)
DEEPSEEK_API_KEY=your_nvidia_api_key_here
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2

# Backward Compatibility
NVIDIA_API_KEY=your_nvidia_api_key_here

# Macro Data Sources
FRED_API_KEY=your_fred_api_key_here

# Orchestration Settings
GEMINI_THROTTLE_SEC=8.0
